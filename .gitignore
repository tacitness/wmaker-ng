# ── Rust ────────────────────────────────────────────────────────────────────
/target/
**/*.rs.bk

# Cargo.lock IS committed — this workspace ships binaries (ng-* / ai-*), so the
# lockfile is part of the reproducible build (house style: PLAN §7).

# ── Packaging artifacts (keep the recipes, ignore the output) ────────────────
/dist/
/out/
packaging/**/*.deb
packaging/**/*.rpm
packaging/**/*.apk

# Transient binary staged into the sandbox build context by `make sandbox-image`.
/sandbox/ai-mcp

# ── Python (ml/) — uv-managed ────────────────────────────────────────────────
ml/.venv/
ml/__pycache__/
ml/**/__pycache__/
ml/**/*.pyc
ml/.ruff_cache/
ml/.mypy_cache/

# ── Editors / OS ─────────────────────────────────────────────────────────────
*.swp
*~
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# ── Secrets / signing keys — never commit ────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.rsa
*.gpg
*-private.asc
